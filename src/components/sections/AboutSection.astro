---
// src/components/sections/AboutSection.astro
// Sección Sobre el Médico - Obtiene datos del doctor internamente

import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';
import Icon from '../ui/Icon.astro';
import { getEntry } from 'astro:content';

// Obtener datos del doctor directamente desde Content Collections
const doctorEntry = await getEntry('doctors', 'dr-dicampli');
const doctor = doctorEntry?.data;

// Extraer datos del doctor
const name = doctor?.name || '';
const doctorTitle = doctor?.title || 'Dr.';
const biography = `${doctor?.title} ${doctor?.name} es un médico pediatra y alergólogo pediátrico con amplia experiencia en el diagnóstico y tratamiento de enfermedades alérgicas en niños y adolescentes.

Su formación académica incluye estudios de postgrado en prestigiosas instituciones internacionales como Johns Hopkins Hospital en Estados Unidos y la Universidad de Florencia en Italia.

Durante sus ${doctor?.experience} años de ejercicio profesional, ha atendido a miles de pacientes, desarrollando un enfoque integral y personalizado para cada caso. Su compromiso es brindar atención médica de excelencia, combinando los avances más recientes de la medicina con un trato humano y cercano.`;

const formation = doctor?.formation || [];
const certifications = doctor?.certifications || [];
const yearsExperience = doctor?.experience || 0;

// Hardcodear valores de CTA
const ctaText = 'Agendar una Consulta';
const ctaHref = '#contacto';

// Mostrar solo las 3 formaciones más recientes
const recentFormation = formation.sort((a, b) => b.year - a.year).slice(0, 3);
---

<section id="sobre-mi" class="py-20 lg:py-28 bg-background">
  <Container>
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      {/* Contenido */}
      <div class="order-2 lg:order-1">
        {/* Badge */}
        <div
          class="inline-flex items-center gap-2 px-4 py-2 bg-primary/10 text-primary rounded-full text-sm font-medium mb-6"
        >
          <Icon name="stethoscope" size={16} />
          <span>Sobre Mí</span>
        </div>

        {/* Título */}
        <h2 class="text-3xl lg:text-4xl font-bold text-text mb-6">
          {doctorTitle}
          <span class="text-primary">{name}</span>
        </h2>

        {/* Biografía */}
        <div class="prose prose-lg text-text-muted mb-8">
          {biography.split('\n\n').map((paragraph) => <p class="mb-4 leading-relaxed">{paragraph}</p>)}
        </div>

        {/* Formación destacada */}
        <div class="mb-8">
          <h3 class="text-lg font-bold text-text mb-4 flex items-center gap-2">
            <Icon name="graduation-cap" size={20} class="text-primary" />
            Formación Académica
          </h3>
          <div class="space-y-3">
            {
              recentFormation.map((edu) => (
                <div class="flex items-start gap-3 p-3 bg-surface rounded-lg border border-border">
                  <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center flex-shrink-0">
                    <span class="text-primary font-bold text-sm">{edu.year}</span>
                  </div>
                  <div>
                    <div class="font-medium text-text">{edu.degree}</div>
                    <div class="text-sm text-text-muted">{edu.institution}</div>
                    {edu.country && <div class="text-xs text-text-muted mt-1">{edu.country}</div>}
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        {/* CTA */}
        <Button variant="primary" size="lg" href={ctaHref} icon="arrow-right" iconPosition="right">
          {ctaText}
        </Button>
      </div>

      {/* Imagen / Video */}
      <div class="order-1 lg:order-2">
        <div class="relative">
          {/* Fondo decorativo */}
          <div
            class="absolute -inset-4 bg-gradient-to-br from-primary/20 to-secondary/20 rounded-3xl transform rotate-2"
          >
          </div>

          {/* Contenido principal */}
          <div class="relative bg-surface rounded-2xl overflow-hidden shadow-xl">
            {
              doctor?.photoProfile ? (
                <img
                  src={doctor.photoProfile}
                  alt={`Foto profesional de ${doctorTitle} ${name}`}
                  class="w-full h-auto object-cover aspect-[4/5]"
                  loading="lazy"
                />
              ) : (
                <div class="aspect-[4/5] bg-gradient-to-br from-primary/10 to-secondary/10 flex items-center justify-center">
                  <div class="text-center p-8">
                    <div class="w-32 h-32 mx-auto mb-4 rounded-full bg-primary/20 flex items-center justify-center">
                      <Icon name="stethoscope" size={64} class="text-primary" />
                    </div>
                    <p class="text-text-muted">
                      {doctorTitle} {name}
                    </p>
                    <p class="text-sm text-text-muted mt-2">Foto profesional</p>
                  </div>
                </div>
              )
            }
          </div>

          {/* Badge flotante - Años de experiencia */}
          <div class="absolute -bottom-6 -left-6 bg-surface shadow-xl rounded-2xl p-5 border border-border">
            <div class="flex items-center gap-4">
              <div class="w-14 h-14 bg-primary rounded-xl flex items-center justify-center">
                <Icon name="star" size={28} class="text-white" />
              </div>
              <div>
                <div class="text-3xl font-bold text-text">{yearsExperience}+</div>
                <div class="text-sm text-text-muted">Años de experiencia</div>
              </div>
            </div>
          </div>

          {/* Badge flotante - Certificaciones (si hay) */}
          {
            certifications.length > 0 && (
              <div class="absolute -top-4 -right-4 bg-primary text-white shadow-xl rounded-xl p-4">
                <div class="flex items-center gap-2">
                  <Icon name="shield-check" size={20} />
                  <span class="font-medium">{certifications.length} Certificaciones</span>
                </div>
              </div>
            )
          }
        </div>
      </div>
    </div>
  </Container>
</section>
