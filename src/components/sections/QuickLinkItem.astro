---
// src/components/sections/QuickLinkItem.astro
// Item individual para la QuickLinksBar

import Icon from '../ui/Icon.astro';

interface Props {
  icon: string;
  title: string;
  subtitle: string;
  dropdownId?: string;
}

const { icon, title, subtitle, dropdownId } = Astro.props;
const uniqueId = dropdownId || `dropdown-${Math.random().toString(36).substr(2, 9)}`;
---

<div class="relative group">
  <button
    class="w-full p-4 lg:p-6 flex flex-col items-center text-center gap-2 lg:gap-3 hover:bg-primary/5 transition-colors"
    data-quicklink
    data-dropdown={uniqueId}
  >
    <div
      class="w-10 h-10 lg:w-12 lg:h-12 rounded-full bg-primary/10 flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-colors"
    >
      <Icon name={icon} size={20} class="lg:w-6 lg:h-6" />
    </div>
    <div>
      <h3 class="font-semibold text-text text-sm lg:text-base">{title}</h3>
      <p class="text-xs lg:text-sm text-text-muted mt-0.5 line-clamp-2">{subtitle}</p>
    </div>
    <Icon name="chevron-down" size={14} class="text-text-muted group-hover:text-primary transition-colors lg:hidden" />
  </button>

  {/* Dropdown - fuera del flujo, se posiciona respecto al div relativo */}
  <div
    id={uniqueId}
    class="absolute top-full left-0 z-50 bg-surface shadow-xl border border-border rounded-xl p-4 lg:p-6 min-w-[320px] w-max max-w-[400px] opacity-0 pointer-events-none transition-all duration-200 translate-y-1"
    data-dropdown-content
  >
    <slot name="dropdown" />
  </div>
</div>

<style>
  /* Cuando el grupo está en hover O el dropdown tiene la clase active */
  .group:hover [data-dropdown-content],
  [data-dropdown-content].active {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }
</style>