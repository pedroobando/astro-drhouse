---
// src/components/sections/Hero.astro
// Hero section principal - Obtiene datos del doctor internamente

import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';
import Icon from '../ui/Icon.astro';
import { Image } from 'astro:assets';
import { getEntry } from 'astro:content';
import type { ImageMetadata } from 'astro';

interface Props {
  // Solo props opcionales para personalización
  image?: ImageMetadata;
  imageUrl?: string;
  imageAlt?: string;
  // Overrides opcionales (si se pasan, usan estos en lugar de los de la BD)
  tagline?: string;
  description?: string;
  ctaPrimary?: {
    text: string;
    href: string;
  };
  ctaSecondary?: {
    text: string;
    href: string;
  };
}

const {
  image,
  imageUrl,
  imageAlt,
  tagline: taglineOverride,
  description: descriptionOverride,
  ctaPrimary = { text: 'Agendar Cita', href: '#contacto' },
  ctaSecondary = { text: 'Ver Servicios', href: '#servicios' },
} = Astro.props;

// Obtener datos del doctor directamente desde Content Collections
const doctorEntry = await getEntry('doctors', 'dr-dicampli');
const doctor = doctorEntry?.data;

// Valores por defecto si no hay doctor en la BD
const doctorName = doctor?.name || '';
const doctorTitle = doctor?.title || 'Dr.';
const doctorSpecialties = doctor?.specialties || [];
const doctorExperience = doctor?.experience || 0;

// Tagline: usar override o generar automáticamente
const tagline = taglineOverride || `${doctorExperience} años cuidando la salud de tus hijos`;

// Descripción: usar override o usar default
const description = descriptionOverride || 
  "Especialista en Pediatría y Alergología Pediátrica con formación internacional en Johns Hopkins y Universidad de Florencia.";

const specialtiesText = doctorSpecialties.join(' | ');
const heroImageAlt = imageAlt || `Consultorio moderno y equipado de ${doctorTitle} ${doctorName}`;
---

<section class="relative min-h-[85vh] flex items-center overflow-hidden">
  {/* Background gradient */}
  <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-background to-secondary/5"></div>

  {/* Decorative elements */}
  <div class="absolute top-20 right-10 w-72 h-72 bg-primary/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-20 left-10 w-96 h-96 bg-secondary/10 rounded-full blur-3xl"></div>

  <Container class="relative z-10 py-16 lg:py-24">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      {/* Content */}
      <div class="text-center lg:text-left">
        {/* Badge de especialidad */}
        <div
          class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/10 text-primary font-medium text-sm mb-6"
        >
          <Icon name="stethoscope" size={16} />
          <span>{specialtiesText}</span>
        </div>

        {/* Nombre y título */}
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-text leading-tight mb-4">
          {doctorTitle}
          <span class="text-primary">{doctorName}</span>
        </h1>

        {/* Tagline */}
        <p class="text-xl md:text-2xl text-text-muted mb-6">
          {tagline}
        </p>

        {/* Descripción */}
        <p class="text-lg text-text-muted mb-8 max-w-xl mx-auto lg:mx-0 leading-relaxed">{description}</p>

        {/* CTAs */}
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <Button variant="primary" size="lg" href={ctaPrimary.href} icon="arrow-right" iconPosition="right">
            {ctaPrimary.text}
          </Button>

          <Button variant="outline" size="lg" href={ctaSecondary.href} icon="arrow-right" iconPosition="right">
            {ctaSecondary.text}
          </Button>
        </div>

        {/* Trust badges */}
        <div class="mt-10 pt-8 border-t border-border">
          <div class="flex flex-wrap justify-center lg:justify-start gap-6 text-sm text-text-muted">
            <div class="flex items-center gap-2">
              <Icon name="shield-check" size={18} class="text-accent" />
              <span>Certificado Internacional</span>
            </div>
            <div class="flex items-center gap-2">
              <Icon name="users" size={18} class="text-accent" />
              <span>+{doctorExperience * 100} pacientes atendidos</span>
            </div>
            <div class="flex items-center gap-2">
              <Icon name="star" size={18} class="text-accent" />
              <span>5.0 en Google Reviews</span>
            </div>
          </div>
        </div>
      </div>

      {/* Image */}
      <div class="relative">
        {
          image ? (
            <div class="relative">
              {/* Decorative ring */}
              <div class="absolute inset-0 bg-gradient-to-br from-primary to-secondary rounded-3xl transform rotate-3 opacity-20" />

              {/* Image container - Usando componente Image de Astro */}
              <div class="relative bg-surface rounded-3xl overflow-hidden shadow-2xl">
                <Image
                  src={image}
                  alt={heroImageAlt}
                  class="w-full h-auto object-cover aspect-[4/5]"
                  loading="lazy"
                  widths={[400, 800]}
                  sizes="(max-width: 768px) 100vw, 50vw"
                  width={image.width}
                  height={image.height}
                />

                {/* Overlay gradient */}
                <div class="absolute inset-0 bg-gradient-to-t from-text/20 to-transparent" />
              </div>

              {/* Floating badge - Consultorio */}
              <div class="absolute -bottom-4 -left-4 bg-surface rounded-2xl shadow-xl p-4 flex items-center gap-3">
                <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center">
                  <Icon name="medical-kit" size={24} class="text-primary" />
                </div>
                <div>
                  <div class="text-sm text-text-muted">Consultorio</div>
                  <div class="font-bold text-text">Moderno Equipado</div>
                </div>
              </div>

              {/* Another floating badge - Disponible */}
              <div class="absolute -top-4 -right-4 bg-primary text-white rounded-2xl shadow-xl p-4">
                <div class="flex items-center gap-2">
                  <Icon name="check-circle" size={20} />
                  <span class="font-medium">Disponible hoy</span>
                </div>
              </div>
            </div>
          ) : imageUrl ? (
            <div class="relative">
              {/* Decorative ring */}
              <div class="absolute inset-0 bg-gradient-to-br from-primary to-secondary rounded-3xl transform rotate-3 opacity-20" />

              {/* Image container con URL externa */}
              <div class="relative bg-surface rounded-3xl overflow-hidden shadow-2xl">
                <img
                  src={imageUrl}
                  alt={heroImageAlt}
                  class="w-full h-auto object-cover aspect-[4/5]"
                  loading="eager"
                />

                {/* Overlay gradient */}
                <div class="absolute inset-0 bg-gradient-to-t from-text/20 to-transparent" />
              </div>

              {/* Floating badge - Consultorio */}
              <div class="absolute -bottom-4 -left-4 bg-surface rounded-2xl shadow-xl p-4 flex items-center gap-3">
                <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center">
                  <Icon name="medical-kit" size={24} class="text-primary" />
                </div>
                <div>
                  <div class="text-sm text-text-muted">Consultorio</div>
                  <div class="font-bold text-text">Moderno Equipado</div>
                </div>
              </div>

              {/* Another floating badge - Disponible */}
              <div class="absolute -top-4 -right-4 bg-primary text-white rounded-2xl shadow-xl p-4">
                <div class="flex items-center gap-2">
                  <Icon name="check-circle" size={20} />
                  <span class="font-medium">Disponible hoy</span>
                </div>
              </div>
            </div>
          ) : (
            /* Placeholder cuando no hay imagen */
            <div class="relative">
              <div class="absolute inset-0 bg-gradient-to-br from-primary to-secondary rounded-3xl transform rotate-3 opacity-20" />
              <div class="relative bg-surface rounded-3xl overflow-hidden shadow-2xl aspect-[4/5] flex items-center justify-center">
                <div class="text-center p-8">
                  <div class="w-32 h-32 mx-auto mb-6 rounded-full bg-primary/10 flex items-center justify-center">
                    <Icon name="stethoscope" size={64} class="text-primary" />
                  </div>
                  <p class="text-text-muted">
                    {doctorTitle} {doctorName}
                  </p>
                  <p class="text-sm text-text-muted mt-2">Foto profesional del médico</p>
                </div>
              </div>
            </div>
          )
        }
      </div>
    </div>
  </Container>

  {/* Scroll indicator */}
  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
    <a href="#quick-links" class="flex flex-col items-center text-text-muted hover:text-primary transition-colors">
      <span class="text-xs mb-2">Conoce más</span>
      <Icon name="chevron-down" size={24} />
    </a>
  </div>
</section>

<style>
  @keyframes bounce {
    0%,
    100% {
      transform: translateX(-50%) translateY(0);
    }
    50% {
      transform: translateX(-50%) translateY(-10px);
    }
  }

  .animate-bounce {
    animation: bounce 2s infinite;
  }
</style>
