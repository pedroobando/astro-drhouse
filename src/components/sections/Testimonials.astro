---
// src/components/sections/Testimonials.astro
// Sección de testimonios de pacientes - Self-contained

import Container from '../ui/Container.astro';
import Icon from '../ui/Icon.astro';
import { getCollection } from 'astro:content';

interface Testimonial {
  name: string;
  role?: string;
  initials: string;
  rating: number;
  text: string;
  service?: string;
  date?: string;
}

interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = "Lo que dicen nuestros pacientes",
  subtitle = "Testimonios de familias que confían en nosotros",
} = Astro.props;

// Obtener testimonios desde Content Collections
const testimonialEntries = await getCollection('testimonials');
const testimonials = testimonialEntries.map((entry) => entry.data as Testimonial);

// Generar estrellas según rating
function getStars(rating: number) {
  return Array.from({ length: 5 }, (_, i) => ({
    filled: i < rating,
  }));
}
---

<section id="testimonios" class="py-20 lg:py-28 bg-surface">
  <Container>
    {/* Header */}
    <div class="text-center max-w-3xl mx-auto mb-12 lg:mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-primary/10 text-primary rounded-full text-sm font-medium mb-6">
        <Icon name="star" size={16} />
        <span>Testimonios</span>
      </div>
      <h2 class="text-3xl lg:text-4xl font-bold text-text mb-4">{title}</h2>
      {subtitle && <p class="text-lg text-text-muted">{subtitle}</p>}
    </div>

    {/* Grid de testimonios */}
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {testimonials.map((testimonial) => (
        <article class="bg-background rounded-2xl p-6 shadow-sm border border-border hover:shadow-md transition-shadow">
          {/* Estrellas */}
          <div class="flex gap-1 mb-4">
            {getStars(testimonial.rating).map((star) => (
              <svg 
                class={`w-5 h-5 ${star.filled ? 'text-yellow-400' : 'text-gray-300'}`}
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          {/* Texto */}
          <blockquote class="text-text-muted mb-6 leading-relaxed">
            "{testimonial.text}"
          </blockquote>

          {/* Autor */}
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold">
              {testimonial.initials}
            </div>
            <div>
              <div class="font-bold text-text">{testimonial.name}</div>
              {testimonial.role && (
                <div class="text-sm text-text-muted">{testimonial.role}</div>
              )}
              {testimonial.service && (
                <div class="text-xs text-primary">{testimonial.service}</div>
              )}
            </div>
          </div>

          {/* Fecha */}
          {testimonial.date && (
            <div class="mt-4 pt-4 border-t border-border">
              <span class="text-xs text-text-muted">{testimonial.date}</span>
            </div>
          )}
        </article>
      ))}
    </div>

    {/* Nota sobre testimonios */}
    <div class="mt-10 text-center">
      <p class="text-sm text-text-muted">
        <Icon name="information-circle" size={16} class="inline mr-1" />
        Todos los testimonios son de pacientes reales que han dado su consentimiento para compartir su experiencia.
      </p>
    </div>
  </Container>
</section>
