---
// src/components/sections/OfficeGallery.astro
// Galería de instalaciones, consultas y procedimientos médicos

import Container from '../ui/Container.astro';
import Icon from '../ui/Icon.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { getCollection } from 'astro:content';

interface GalleryImage {
  image: ImageMetadata;
  caption: string;
  category?: 'instalaciones' | 'consulta' | 'procedimiento' | 'equipo';
}

interface Props {
  title?: string;
  subtitle?: string;
  // images: GalleryImage[];
  columns?: 2 | 3 | 4;
  showLightbox?: boolean;
}

const galleryEntries = await getCollection('gallery');

const galleryImages: GalleryImage[] = galleryEntries
  .filter((entry) => entry.data.active)
  .sort((a, b) => a.data.order - b.data.order)
  .map((entry) => ({
    image: entry.data.image,
    caption: entry.data.caption,
    category: entry.data.category,
  }));

const {
  title = 'Nuestras Instalaciones',
  subtitle = 'Conoce el espacio donde cuidamos de tu salud',
  // images = [],
  columns = 3,
  showLightbox = true,
} = Astro.props;

// Configuración de columnas
const columnClasses = {
  2: 'grid-cols-1 md:grid-cols-2',
  3: 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3',
  4: 'grid-cols-1 md:grid-cols-2 lg:grid-cols-4',
};

// Iconos por categoría
const categoryIcons: Record<string, string> = {
  instalaciones: 'medical-kit',
  consulta: 'stethoscope',
  procedimiento: 'heart-pulse',
  equipo: 'shield-check',
};

// Colores por categoría
const categoryColors: Record<string, string> = {
  instalaciones: 'bg-blue-500',
  consulta: 'bg-green-500',
  procedimiento: 'bg-purple-500',
  equipo: 'bg-orange-500',
};
---

<section id="instalaciones" class="py-20 lg:py-28 bg-surface">
  <Container>
    {/* Header */}
    <div class="text-center max-w-3xl mx-auto mb-12 lg:mb-16">
      <div
        class="inline-flex items-center gap-2 px-4 py-2 bg-primary/10 text-primary rounded-full text-sm font-medium mb-6"
      >
        <Icon name="medical-kit" size={16} />
        <span>Galería</span>
      </div>
      <h2 class="text-3xl lg:text-4xl font-bold text-text mb-4">{title}</h2>
      {subtitle && <p class="text-lg text-text-muted">{subtitle}</p>}
    </div>

    {/* Grid de imágenes */}
    <div class={`grid ${columnClasses[columns]} gap-6 lg:gap-8`}>
      {
        galleryImages.map((item, index) => (
          <div
            class="group relative rounded-2xl overflow-hidden shadow-lg cursor-pointer"
            data-gallery-item
            data-index={index}
          >
            {/* Imagen */}
            <div class="aspect-[4/3] overflow-hidden">
              <Image
                src={item.image.src}
                alt={item.caption}
                width={item.image.width}
                height={item.image.height}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                loading={index < 3 ? 'eager' : 'lazy'}
                widths={[400, 800]}
                sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw"
              />
            </div>

            {/* Overlay gradiente */}
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-60 group-hover:opacity-80 transition-opacity" />

            {/* Categoría badge (esquina superior izquierda) */}
            {item.category && (
              <div
                class={`absolute top-4 left-4 px-3 py-1.5 rounded-full text-white text-xs font-medium flex items-center gap-1.5 ${categoryColors[item.category] || 'bg-primary'}`}
              >
                <Icon name={categoryIcons[item.category] || 'information-circle'} size={14} />
                <span class="capitalize">{item.category}</span>
              </div>
            )}

            {/* Caption/Leyenda (footer de la imagen) */}
            <div class="absolute bottom-0 left-0 right-0 p-4 transform translate-y-2 group-hover:translate-y-0 transition-transform">
              <p class="text-white text-sm font-medium text-center">{item.caption}</p>
            </div>

            {/* Icono de ampliar (esquina superior derecha) */}
            {showLightbox && (
              <div class="absolute top-4 right-4 w-10 h-10 bg-white/20 backdrop-blur-sm rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                <Icon name="search" size={20} class="text-white" />
              </div>
            )}
          </div>
        ))
      }
    </div>

    {/* Nota de pie de página */}
    <div class="mt-10 p-4 bg-background rounded-xl border border-border flex items-start gap-3">
      <Icon name="information-circle" size={20} class="text-primary flex-shrink-0 mt-0.5" />
      <p class="text-sm text-text-muted">
        <strong>Nota importante:</strong> Todas las imágenes de pacientes han sido publicadas con consentimiento informado
        previo. Las fotografías de procedimientos médicos son realizadas por personal especializado. Algunas imágenes pueden
        ser ilustrativas del tipo de atención proporcionada.
      </p>
    </div>
  </Container>
</section>

{/* Lightbox Modal */}
{
  showLightbox && (
    <div
      id="gallery-lightbox"
      class="fixed inset-0 z-50 bg-black/95 hidden items-center justify-center p-4"
      data-lightbox
    >
      {/* Botón cerrar */}
      <button
        class="absolute top-4 right-4 w-12 h-12 bg-white/10 hover:bg-white/20 rounded-full flex items-center justify-center text-white transition-colors z-10"
        data-lightbox-close
        aria-label="Cerrar"
      >
        <Icon name="close" size={24} />
      </button>

      {/* Navegación anterior */}
      <button
        class="absolute left-4 top-1/2 -translate-y-1/2 w-12 h-12 bg-white/10 hover:bg-white/20 rounded-full flex items-center justify-center text-white transition-colors"
        data-lightbox-prev
        aria-label="Anterior"
      >
        <Icon name="arrow-left" size={24} />
      </button>

      {/* Navegación siguiente */}
      <button
        class="absolute right-4 top-1/2 -translate-y-1/2 w-12 h-12 bg-white/10 hover:bg-white/20 rounded-full flex items-center justify-center text-white transition-colors"
        data-lightbox-next
        aria-label="Siguiente"
      >
        <Icon name="arrow-right" size={24} />
      </button>

      {/* Contenedor de imagen */}
      <div class="max-w-5xl max-h-[80vh] relative" data-lightbox-container>
        <img src="" alt="" class="max-w-full max-h-[80vh] object-contain rounded-lg" data-lightbox-image />
        {/* Caption en lightbox */}
        <p class="text-white text-center mt-4 text-lg" data-lightbox-caption />
      </div>

      {/* Contador */}
      <div class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white/70 text-sm">
        <span data-lightbox-current>1</span> / <span data-lightbox-total>{galleryImages.length}</span>
      </div>
    </div>
  )
}

<script>
  // Lightbox functionality
  document.addEventListener('DOMContentLoaded', () => {
    const galleryItems = document.querySelectorAll('[data-gallery-item]');
    const lightbox = document.querySelector('[data-lightbox]');
    const lightboxImage = document.querySelector('[data-lightbox-image]') as HTMLImageElement;
    const lightboxCaption = document.querySelector('[data-lightbox-caption]');
    const lightboxCurrent = document.querySelector('[data-lightbox-current]');
    const lightboxClose = document.querySelector('[data-lightbox-close]');
    const lightboxPrev = document.querySelector('[data-lightbox-prev]');
    const lightboxNext = document.querySelector('[data-lightbox-next]');

    let currentIndex = 0;
    const images = Array.from(galleryItems).map((item) => ({
      src: item.querySelector('img')?.src || '',
      caption: item.querySelector('p')?.textContent || '',
    }));

    function openLightbox(index: number) {
      currentIndex = index;
      if (lightboxImage && lightboxCaption && lightboxCurrent) {
        lightboxImage.src = images[index].src;
        lightboxCaption.textContent = images[index].caption;
        lightboxCurrent.textContent = String(index + 1);
      }
      lightbox?.classList.remove('hidden');
      lightbox?.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      lightbox?.classList.add('hidden');
      lightbox?.classList.remove('flex');
      document.body.style.overflow = '';
    }

    function prevImage() {
      currentIndex = currentIndex > 0 ? currentIndex - 1 : images.length - 1;
      openLightbox(currentIndex);
    }

    function nextImage() {
      currentIndex = currentIndex < images.length - 1 ? currentIndex + 1 : 0;
      openLightbox(currentIndex);
    }

    // Event listeners
    galleryItems.forEach((item, index) => {
      item.addEventListener('click', () => openLightbox(index));
    });

    lightboxClose?.addEventListener('click', closeLightbox);
    lightboxPrev?.addEventListener('click', prevImage);
    lightboxNext?.addEventListener('click', nextImage);

    // Cerrar con Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') prevImage();
      if (e.key === 'ArrowRight') nextImage();
    });

    // Cerrar al hacer click fuera
    lightbox?.addEventListener('click', (e) => {
      if (e.target === lightbox) closeLightbox();
    });
  });
</script>
