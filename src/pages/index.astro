---
// src/pages/index.astro - Página de Inicio completa

import MainLayout from '@/layouts/MainLayout.astro';
import Hero from '@/components/sections/Hero.astro';
import QuickLinksBar from '@/components/sections/QuickLinksBar.astro';
import FeaturesBar from '@/components/sections/FeaturesBar.astro';
import AboutSection from '@/components/sections/AboutSection.astro';
import ServicesGrid from '@/components/sections/ServicesGrid.astro';
import OfficeGallery from '@/components/sections/OfficeGallery.astro';
import FAQSection from '@/components/sections/FAQSection.astro';
import Testimonials from '@/components/sections/Testimonials.astro';
import ContactForm from '@/components/forms/ContactForm.astro';
import { getEntry } from 'astro:content';

// Importar imagenes usando astro:assets
// Hero: foto del consultorio (oficina)
import officeImage from '../content/images/office-01.png';
// import officeImage2 from '../content/images/office-02.png';
// About: foto del perfil del doctor
import doctorProfileImage from '@/content/images/dr-dicampli.png';

// Obtener datos del doctor para el título y descripción de la página
const doctorEntry = await getEntry('doctors', 'dr-dicampli');
const doctor = doctorEntry?.data;
---

<MainLayout
  title={`${doctor?.title} ${doctor?.name} - ${doctor?.specialties?.join(' & ')}`}
  description={`${doctor?.specialties?.join(' y ')}. Más de ${doctor?.experience} años de experiencia en Lechería, Anzoátegui.`}
>
  <!-- 1. Hero Section - Componente inteligente que obtiene datos del doctor -->
  <Hero image={officeImage} />

  <!-- 2. QuickLinksBar - Componente inteligente con múltiples sedes -->
  <QuickLinksBar />

  <!-- 3. FeaturesBar -->
  <FeaturesBar variant="colored" />

  <!-- 4. About Section - Foto del PERFIL del doctor -->
  <AboutSection />

  <!-- <Image src={doctorProfileImage.src} width={300} height={300} alt={'imagen doctorgit'} /> -->

  <!-- 6. Services Grid - Self-contained, obtiene datos internamente -->
  <ServicesGrid />

  <!-- 5. Office Gallery - Self-contained, obtiene datos internamente -->
  <OfficeGallery />

  <!-- 7. FAQ Section - Self-contained, obtiene datos internamente -->
  <FAQSection />

  <!-- 8. Testimonials Section - Self-contained, obtiene datos internamente -->
  <Testimonials />

  <!-- 9. Contact Form Section - Self-contained, obtiene datos internamente -->
  <ContactForm />
</MainLayout>
