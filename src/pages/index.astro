---
// src/pages/index.astro - Página de Inicio completa
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/sections/Hero.astro';
import QuickLinksBar from '../components/sections/QuickLinksBar.astro';
import FeaturesBar from '../components/sections/FeaturesBar.astro';
import AboutSection from '../components/sections/AboutSection.astro';
import ServicesGrid from '../components/sections/ServicesGrid.astro';
import OfficeGallery from '../components/sections/OfficeGallery.astro';
import FAQSection from '../components/sections/FAQSection.astro';
import Icon from '../components/ui/Icon.astro';
import { getEntry, getCollection } from 'astro:content';

// Importar imagenes usando astro:assets
// Hero: foto del consultorio (oficina)
import officeImage from '../content/images/offices/office-01.png';
import officeImage2 from '../content/images/offices/office-02.png';
// About: foto del perfil del doctor
import doctorProfileImage from '../content/images/profile/dr-dicampli.png';
// Galería: procedimientos médicos
import procedure01 from '../content/images/procedure/procedure-01.png';
import procedure02 from '../content/images/procedure/procedure-02.png';
import procedure03 from '../content/images/procedure/procedure-03.png';
import procedure04 from '../content/images/procedure/procedure-04.png';

// Imágenes para la galería
const galleryImages = [
  {
    image: officeImage,
    caption: "Sala de consulta equipada con tecnología moderna",
    category: "instalaciones" as const,
  },
  {
    image: officeImage2,
    caption: "Área de espera cómoda y climatizada",
    category: "instalaciones" as const,
  },
  {
    image: doctorProfileImage,
    caption: "Consulta pediátrica con consentimiento informado",
    category: "consulta" as const,
  },
  {
    image: procedure01,
    caption: "Evaluación completa del paciente",
    category: "procedimiento" as const,
  },
  {
    image: procedure02,
    caption: "Procedimiento realizado por especialista",
    category: "procedimiento" as const,
  },
  {
    image: procedure03,
    caption: "Seguimiento post-procedimiento",
    category: "procedimiento" as const,
  },
  {
    image: procedure04,
    caption: "Atención especializada pediátrica",
    category: "consulta" as const,
  },
];

// Obtener datos del doctor
const doctorEntry = await getEntry('doctors', 'dr-dicampli');
const doctor = doctorEntry?.data;

// Obtener servicios ordenados
const servicesEntries = await getCollection('services');
const services = servicesEntries.sort((a, b) => a.data.order - b.data.order);

// Preparar datos
const workingHours = [
  { days: "Lun - Vie", hours: "8:00 AM - 5:00 PM" },
  { days: "Sábados", hours: "9:00 AM - 1:00 PM" },
  { days: "Domingos", hours: "Cerrado" },
];

const clinics = doctor?.clinics?.map(c => ({
  name: c.name,
  address: c.address,
  phone: c.phone,
})) || [];

// Features
const features = [
  {
    icon: "shield-check",
    title: `${doctor?.experience} Años de Experiencia`,
    description: "Trayectoria sólida en Pediatría y Alergología Pediátrica, atendiendo a miles de pacientes."
  },
  {
    icon: "graduation-cap",
    title: "Formación Internacional",
    description: "Fellowship en Johns Hopkins Hospital y Universidad de Florencia. Excelencia académica."
  },
  {
    icon: "heart",
    title: "Atención Personalizada",
    description: "Cada paciente recibe atención individualizada, tratándolos como miembros de nuestra familia."
  }
];

// Servicios mapeados
const mappedServices = services.map((s, i) => ({
  title: s.data.title,
  description: s.body?.slice(0, 120).replace(/[#*]/g, '') + '...',
  icon: s.data.category === 'pediatria' ? 'stethoscope' : 'heart-pulse',
  slug: s.data.category,
  featured: i === 0,
}));

// FAQs
const faqs = [
  {
    question: "¿Qué documentos debo llevar a la primera consulta?",
    answer: "Para la primera consulta, es importante traer la cédula de identidad del niño, carnet de vacunación actualizado, exámenes médicos previos relevantes, y cualquier medicamento que esté tomando actualmente. Si tiene seguro médico, también traiga la tarjeta."
  },
  {
    question: "¿Cuánto dura una consulta de alergología?",
    answer: "La primera consulta de alergología dura aproximadamente 45-60 minutos, ya que incluye una evaluación completa del historial médico, examen físico detallado y discusión del plan de tratamiento. Las consultas de seguimiento suelen durar 20-30 minutos."
  },
  {
    question: "¿Realizan pruebas de alergia en el consultorio?",
    answer: "Sí, realizamos pruebas cutáneas de alergia (skin prick test) en el consultorio. Son pruebas rápidas, seguras y prácticamente indoloras que nos permiten identificar alergias a alimentos, polen, ácaros, moho y pelos de animales. Los resultados están disponibles en 15-20 minutos."
  },
  {
    question: "¿Atienden emergencias pediátricas?",
    answer: "Atendemos emergencias leves y moderadas durante nuestros horarios de consulta. Para emergencias graves que ponen en riesgo la vida, recomendamos acudir inmediatamente al servicio de emergencias del hospital más cercano."
  },
  {
    question: "¿Cómo puedo agendar una cita?",
    answer: "Puede agendar su cita de varias formas: llamando a nuestro número de teléfono, enviando un mensaje por WhatsApp, o completando el formulario de contacto en nuestra página web. Le responderemos en menos de 24 horas para confirmar su cita."
  }
];
---

<MainLayout 
  title={`${doctor?.title} ${doctor?.name} - ${doctor?.specialties?.join(' & ')}`}
  description={`${doctor?.specialties?.join(' y ')}. Más de ${doctor?.experience} años de experiencia en Lechería, Anzoátegui.`}
>
  <!-- 1. Hero Section - Foto del CONSULTORIO -->
  <Hero 
    name={doctor?.name || ''}
    title={doctor?.title || 'Dr.'}
    specialties={doctor?.specialties || []}
    experience={doctor?.experience || 0}
    tagline={`${doctor?.experience} años cuidando la salud de tus hijos`}
    description="Especialista en Pediatría y Alergología Pediátrica con formación internacional en Johns Hopkins y Universidad de Florencia."
    ctaPrimary={{ text: "Agendar Cita", href: "#contacto" }}
    ctaSecondary={{ text: "Ver Servicios", href: "#servicios" }}
    image={officeImage}
    imageAlt={`Consultorio moderno y equipado de ${doctor?.title} ${doctor?.name}`}
  />

  <!-- 2. QuickLinksBar -->
  <QuickLinksBar 
    location={{
      address: doctor?.contact?.address || '',
      mapUrl: "https://maps.google.com/?q=Centro+Médico+Lechería",
      clinics: clinics,
    }}
    workingHours={workingHours}
    phone={doctor?.contact?.phone || ''}
    whatsapp={doctor?.contact?.whatsapp || ''}
    email={doctor?.contact?.email}
  />

  <!-- 3. FeaturesBar -->
  <FeaturesBar 
    variant="colored"
    features={features}
  />

  <!-- 4. About Section - Foto del PERFIL del doctor -->
  <AboutSection
    name={doctor?.name || ''}
    title={doctor?.title || 'Dr.'}
    biography={`${doctor?.title} ${doctor?.name} es un médico pediatra y alergólogo pediátrico con amplia experiencia en el diagnóstico y tratamiento de enfermedades alérgicas en niños y adolescentes.

Su formación académica incluye estudios de postgrado en prestigiosas instituciones internacionales como Johns Hopkins Hospital en Estados Unidos y la Universidad de Florencia en Italia.

Durante sus ${doctor?.experience} años de ejercicio profesional, ha atendido a miles de pacientes, desarrollando un enfoque integral y personalizado para cada caso. Su compromiso es brindar atención médica de excelencia, combinando los avances más recientes de la medicina con un trato humano y cercano.`}
    formation={doctor?.formation || []}
    certifications={doctor?.certifications || []}
    yearsExperience={doctor?.experience || 0}
    image={doctorProfileImage}
  />

  <!-- 5. Office Gallery - Instalaciones y consultas -->
  <OfficeGallery
    title="Nuestras Instalaciones"
    subtitle="Espacios diseñados para el bienestar y comodidad de nuestros pacientes"
    images={galleryImages}
    columns={3}
  />

  <!-- 5. Services Grid -->
  <ServicesGrid 
    title="Nuestros Servicios"
    subtitle="Atención médica integral especializada en Pediatría y Alergología Pediátrica"
    services={mappedServices}
    layout="grid"
  />

  <!-- 6. FAQ Section -->
  <FAQSection 
    title="Preguntas Frecuentes"
    subtitle="Resolvemos tus dudas sobre nuestras consultas y servicios"
    faqs={faqs}
    layout="single"
  />

  <!-- 7. CTA Final -->
  <section id="contacto" class="py-20 lg:py-28 bg-gradient-to-br from-primary to-secondary text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        ¿Listo para agendar una cita?
      </h2>
      <p class="text-white/90 text-lg max-w-2xl mx-auto mb-8">
        Tu hijo merece la mejor atención médica. Contamos con horarios flexibles 
        y atención personalizada.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a 
          href={`https://wa.me/${doctor?.contact?.whatsapp?.replace(/\D/g, '')}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-4 bg-white text-primary rounded-xl font-semibold hover:bg-white/90 transition-colors shadow-lg"
        >
          <Icon name="whatsapp" size={20} />
          WhatsApp
        </a>
        <a 
          href={`tel:${doctor?.contact?.phone}`}
          class="inline-flex items-center gap-2 px-8 py-4 bg-white/20 text-white rounded-xl font-semibold hover:bg-white/30 transition-colors backdrop-blur-sm"
        >
          <Icon name="phone" size={20} />
          Llamar Ahora
        </a>
      </div>
    </div>
  </section>
</MainLayout>
