---
// src/layouts/MainLayout.astro - Layout Principal
import '@/styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { getEntry } from 'astro:content';

interface Props {
  title: string;
  description?: string;
  theme?: string;
}

const {
  title,
  description = 'Dr. Mario Antonio Di Campli-Palermo - Pediatría y Alergología Pediátrica en Lechería, Anzoátegui',
  theme = 'pediatra',
} = Astro.props;

// Obtener datos del doctor
const doctorEntry = await getEntry('doctors', 'dr-dicampli');
const doctor = doctorEntry?.data;
---

<!doctype html>
<html lang="es" data-theme={theme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0ea5e9" />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | DrHouse`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <title>{title}</title>

    <!-- View Transitions - ClientRouter -->
    <ClientRouter />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preconnect para performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />

    <!-- Schema.org / JSON-LD para SEO Local -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "MedicalBusiness",
          "@id": "https://drhouse-medical.com/#business",
          "name": `${doctor?.title} ${doctor?.name}`,
          "description": description,
          "url": "https://drhouse-medical.com",
          "telephone": doctor?.contact?.phone,
          "email": doctor?.contact?.email,
          "address": {
            "@type": "PostalAddress",
            "streetAddress": doctor?.contact?.address,
            "addressLocality": "Lechería",
            "addressRegion": "Anzoátegui",
            "addressCountry": "VE"
          },
          "geo": {
            "@type": "GeoCoordinates",
            "latitude": "10.1858",
            "longitude": "-64.6852"
          },
          "openingHours": ["Mo-Fr 08:00-17:00", "Sa 09:00-13:00"],
          "priceRange": "$$",
          "image": "https://drhouse-medical.com/images/doctor.jpg",
          "sameAs": [
            doctor?.contact?.social?.instagram,
            doctor?.contact?.social?.facebook
          ].filter(Boolean)
        },
        {
          "@type": "Physician",
          "@id": "https://drhouse-medical.com/#physician",
          "name": `${doctor?.title} ${doctor?.name}`,
          "medicalSpecialty": doctor?.specialties,
          "description": `${doctor?.experience} años de experiencia en ${doctor?.specialties?.join(' y ')}`,
          "alumniOf": doctor?.formation?.map(f => ({
            "@type": "EducationalOrganization",
            "name": f.institution,
            "department": f.degree
          })),
          "memberOf": doctor?.certifications?.map(c => ({
            "@type": "Organization",
            "name": c.institution
          })),
          "worksFor": {
            "@id": "https://drhouse-medical.com/#business"
          },
          "areaServed": {
            "@type": "City",
            "name": "Lechería, Barcelona, Puerto La Cruz"
          }
        }
      ]
    })} />
  </head>
  <body class="bg-background text-text min-h-screen flex flex-col">
    <!-- Header -->
    <Header 
      logo="DrHouse"
      phone={doctor?.contact?.phone}
      whatsapp={doctor?.contact?.whatsapp}
    />

    <!-- Contenido Principal -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer -->
    <Footer 
      name={doctor?.name || 'Di Campli'}
      title={doctor?.title || 'Dr.'}
      specialties={doctor?.specialties || []}
      phone={doctor?.contact?.phone}
      whatsapp={doctor?.contact?.whatsapp}
      email={doctor?.contact?.email}
      address={doctor?.contact?.address}
      clinics={doctor?.clinics || []}
    />
  </body>
</html>
