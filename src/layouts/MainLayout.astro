---
// src/layouts/MainLayout.astro - Layout Principal
import '@/styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { getEntry } from 'astro:content';

interface Props {
  title: string;
  description?: string;
  theme?: string;
}

const {
  title,
  description = 'Dr. Mario Antonio Di Campli-Palermo - Pediatría y Alergología Pediátrica en Lechería, Anzoátegui',
  theme = 'pediatra',
} = Astro.props;

// Obtener datos del doctor
const doctorEntry = await getEntry('doctors', 'dr-dicampli');
const doctor = doctorEntry?.data;
---

<!doctype html>
<html lang="es" data-theme={theme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0ea5e9" />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | DrHouse`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preconnect para performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
  </head>
  <body class="bg-background text-text min-h-screen flex flex-col">
    <!-- Header -->
    <Header 
      logo="DrHouse"
      phone={doctor?.contact?.phone}
      whatsapp={doctor?.contact?.whatsapp}
    />

    <!-- Contenido Principal -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer -->
    <Footer 
      name={doctor?.name || 'Di Campli'}
      title={doctor?.title || 'Dr.'}
      specialties={doctor?.specialties || []}
      phone={doctor?.contact?.phone}
      whatsapp={doctor?.contact?.whatsapp}
      email={doctor?.contact?.email}
      address={doctor?.contact?.address}
      clinics={doctor?.clinics || []}
    />
  </body>
</html>
